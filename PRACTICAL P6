#include <stdio.h>

int main()
{
    int pages[] = {1,2,3,1,4,5};
    int frame[3];
    int i,j,k=0;

    for(i=0;i<3;i++)
        frame[i]=-1;

    for(i=0;i<6;i++)
    {
        int found=0;

        for(j=0;j<3;j++)
        {
            if(frame[j]==pages[i])
                found=1;
        }

        if(!found)
        {
            frame[k]=pages[i];
            k=(k+1)%3;
        }

        printf("Frames: ");

        for(j=0;j<3;j++)
            printf("%d ",frame[j]);

        printf("\n");
    }

    return 0;
}
