#include <stdio.h>

int queue[10], front = -1, rear = -1;

void enqueue(int x)
{
    if(front == -1)
        front = 0;
    queue[++rear] = x;
}

void display()
{
    int i;
    printf("Ready Queue: ");
    for(i = front; i <= rear; i++)
        printf("%d ", queue[i]);
}

int main()
{
    enqueue(1);
    enqueue(2);
    enqueue(3);

    display();

    return 0;
}
