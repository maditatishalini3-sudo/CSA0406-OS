#include <stdio.h>
#include <unistd.h>
#include <sys/wait.h>

int main()
{
    if (fork() == 0)
    {
        printf("Child 1 ID: %d\n", getpid());
        return 0;
    }

    wait(NULL);

    if (fork() == 0)
    {
        printf("Child 2 ID: %d\n", getpid());
        return 0;
    }

    wait(NULL);

    printf("Parent ID: %d\n", getpid());

    return 0;
}
