#include<stdio.h>
#include<fcntl.h>
#include<unistd.h>
int main()
{
int f1,f2;
char c;
f1=open("a.txt",O_RDONLY);
f2=open("b.txt",O_WRONLY|O_CREAT,0666);
while(read(f1,&c,1))
write(f2,&c,1);
close(f1);
close(f2);
return 0;
}
