#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>

int main()
{
    char msg[] = "Hello OS Lab";

    int fd = open("test.txt", O_CREAT | O_WRONLY, 0644);

    write(fd, msg, sizeof(msg));

    close(fd);

    char buffer[50];

    fd = open("test.txt", O_RDONLY);

    read(fd, buffer, sizeof(buffer));

    printf("%s\n", buffer);

    close(fd);

    return 0;
}
